TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional comma-separated allowlist. When set, only these chat IDs can use the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional comma-separated username allowlist. Usernames can be written with or without @.
TELEGRAM_ALLOWED_USERNAMES=
# Send the item photo with each alert (as a Telegram photo + caption). Set false for text-only.
TELEGRAM_SEND_PHOTOS=true

# eBay API credentials (required). Create an application keyset at
# https://developer.ebay.com and use the Production App ID (Client ID)
# and Cert ID (Client Secret).
EBAY_APP_ID=
EBAY_CLIENT_SECRET=
# Marketplace to search, e.g. EBAY-US, EBAY-GB, EBAY-DE, EBAY-AU.
EBAY_GLOBAL_ID=EBAY-US

# Comma-separated sellers to seed at startup. You can also add sellers via Telegram.
SELLERS=
# Comma-separated sellers to seed onto the fast-poll observe list at startup.
# Observe-list sellers are checked for newly listed items only, on their own
# interval. You can also manage these from Telegram with /observe.
OBSERVE_SELLERS=

SQLITE_PATH=ebayspy.sqlite3
POLL_INTERVAL_SECONDS=900
SELLER_CHECK_DELAY_SECONDS=0
MAX_ITEMS_PER_SELLER=20
# Parallel eBay item-detail lookups per seller. Higher = faster polls but more API calls.
DETAIL_CONCURRENCY=5
NOTIFY_EXISTING_ON_FIRST_RUN=false
HTTP_TIMEOUT_SECONDS=20

# Observe list: a separate, faster lane that alerts only on newly listed items.
# Default interval (seconds) for an observe-list seller when no per-seller
# interval is set. Each observe poll is one cheap search call; detail is fetched
# only for genuinely new items, so a tight cadence stays affordable.
OBSERVE_INTERVAL_SECONDS=180
# Floor for any observe interval, to avoid hammering the API by accident.
OBSERVE_MIN_INTERVAL_SECONDS=30

# Market watches: alert when a Buy It Now listing appears below the going rate.
# "Market price" is the trimmed median total cost (item + shipping) of the live
# listings matching each watch. Manage watches from Telegram with /watch.
# Semicolon-separated queries to seed at startup (queries may contain commas).
MARKET_WATCHES=
# How often (seconds) to reprice each watch and scan for deals. One search call per watch.
MARKET_INTERVAL_SECONDS=600
# Floor for any per-watch interval.
MARKET_MIN_INTERVAL_SECONDS=120
# Default discount below market that counts as a deal (per-watch override via /watch ... discount:%).
MARKET_DISCOUNT_PERCENT=15
# How many live listings to sample per watch when computing the market price (max 200).
MARKET_SAMPLE_SIZE=200
# Ignore "deals" priced below this fraction of market (almost always the wrong item or a scam).
MARKET_MIN_DEAL_RATIO=0.4
# Cap deal alerts per watch per cycle so a first-run backlog never floods the chat.
MARKET_MAX_DEALS_PER_CYCLE=5
# Minimum number of *comparable* listings before a market price is trusted and deals fire.
# Guards against mis-pricing when a query is too narrow or too broad.
MARKET_MIN_SAMPLE=5
# Fraction of a watch's keywords that must appear in a listing title for it to count as the
# same product (0-1). Higher = stricter matching. The model number (e.g. hu02) is always required.
MARKET_MATCH_COVERAGE=0.6
# When a watch leaves a variant open (e.g. no capacity/colour given), ebayspy prices each
# variant separately if their prices differ by at least this fraction. Lower = split more
# eagerly; higher = only split when the variant clearly moves the price.
MARKET_MIN_DISPERSION=0.12
# Add a second cheapest-first search pass per watch to catch deep-page deals. Doubles the API
# cost per watch; off by default. The default Best Match pass already prices the market correctly.
MARKET_DEAL_SCAN=false

# --- Matching engine (hybrid: rules + fuzzy + semantic + eBay structured data) ---
# Fuzzy (rapidfuzz) relevance threshold (0-1) for word-order/typo tolerance.
MARKET_FUZZY_THRESHOLD=0.88
# Semantic matching via static embeddings (install the 'nlp' extra: pip install -e ".[nlp]").
# Generalises to any category. Auto-disables gracefully if the model isn't installed.
MARKET_SEMANTIC=true
MARKET_SEMANTIC_THRESHOLD=0.6
# Enrich comparable listings with eBay's structured catalog data (ePID, GTIN, MPN, aspects)
# so variant clustering uses authoritative values, not title-guessing. Costs one getItem call
# per hydrated item — bounded by the limit below. Set false to save API budget.
MARKET_HYDRATE=true
MARKET_HYDRATE_LIMIT=20
# Where the market price comes from: 'listings' (live asking prices, default) or 'insights'
# (real sold prices via the Marketplace Insights API — requires approved Limited-Release
# access; falls back to listings automatically if the call is not entitled).
MARKET_PRICE_SOURCE=listings

# --- Deal economics (flip profit/ROI shown on each deal) ---
# Seller fee assumed when estimating resale profit: a percentage plus a fixed per-order charge.
MARKET_RESALE_FEE_PERCENT=12.8
MARKET_RESALE_FEE_FIXED=0.30

# --- Auctions & sniping (opt in per watch with 'auctions:on') ---
# Default for watches that don't say auctions:on/off.
MARKET_AUCTIONS_DEFAULT=false
# How close to an auction's end counts as the 'final call' (a second, urgent alert).
MARKET_SNIPE_WINDOW_SECONDS=600
# Tight poll cadence used while an auction is near its end so the final call lands in time.
MARKET_TURBO_INTERVAL_SECONDS=45

# --- Demand / liquidity read (collected over time) ---
# A listing absent from the sample beyond this grace counts as sold/ended (guards ranking churn).
MARKET_DEMAND_GRACE_SECONDS=86400
# Window for demand metrics (disappearances per week, etc).
MARKET_DEMAND_WINDOW_DAYS=14
# Minimum disappearance events before the demand read is shown (else 'warming up').
MARKET_DEMAND_MIN_EVENTS=3

# --- Cross-marketplace arbitrage (opt in per watch with 'markets:GB,DE,US') ---
# Minimum converted price gap between marketplaces to alert.
MARKET_ARBITRAGE_THRESHOLD=20
# How often the (multi-search) arbitrage check runs per watch.
MARKET_ARBITRAGE_INTERVAL_SECONDS=3600
# Optional static FX fallbacks (units per 1 USD), used if the live FX fetch fails. e.g. GBP=0.79,EUR=0.92
FX_RATES=

# --- Watch health ---
# Alert once when a watch errors or finds no comparables this many checks in a row.
MARKET_HEALTH_THRESHOLD=5

# Synonyms folded together for search + matching (ps5 <-> playstation 5). e.g. ps5=playstation 5;series x=xbox series x
ALIASES=
