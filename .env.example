TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional comma-separated allowlist. When set, only these chat IDs can use the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional comma-separated username allowlist. Usernames can be written with or without @.
TELEGRAM_ALLOWED_USERNAMES=

# eBay API credentials (required). Create an application keyset at
# https://developer.ebay.com and use the Production App ID (Client ID)
# and Cert ID (Client Secret).
EBAY_APP_ID=
EBAY_CLIENT_SECRET=
# Marketplace to search, e.g. EBAY-US, EBAY-GB, EBAY-DE, EBAY-AU.
EBAY_GLOBAL_ID=EBAY-US

# Comma-separated sellers to seed at startup. You can also add sellers via Telegram.
SELLERS=
# Comma-separated sellers to seed onto the fast-poll observe list at startup.
# Observe-list sellers are checked for newly listed items only, on their own
# interval. You can also manage these from Telegram with /observe.
OBSERVE_SELLERS=

SQLITE_PATH=ebayspy.sqlite3
POLL_INTERVAL_SECONDS=900
SELLER_CHECK_DELAY_SECONDS=0
MAX_ITEMS_PER_SELLER=20
# Parallel eBay item-detail lookups per seller. Higher = faster polls but more API calls.
DETAIL_CONCURRENCY=5
NOTIFY_EXISTING_ON_FIRST_RUN=false
HTTP_TIMEOUT_SECONDS=20

# Observe list: a separate, faster lane that alerts only on newly listed items.
# Default interval (seconds) for an observe-list seller when no per-seller
# interval is set. Each observe poll is one cheap search call; detail is fetched
# only for genuinely new items, so a tight cadence stays affordable.
OBSERVE_INTERVAL_SECONDS=180
# Floor for any observe interval, to avoid hammering the API by accident.
OBSERVE_MIN_INTERVAL_SECONDS=30
